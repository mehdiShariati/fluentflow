# Copy to `.env` for docker compose variable substitution, or export for local dev.

# --- Core API ---
DATABASE_URL=postgres://fluentflow:fluentflow@localhost:5432/fluentflow?sslmode=disable
JWT_SECRET=change-me-at-least-16-chars
HTTP_ADDR=:8080
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- OpenAI (recommended) ---
# Live agent: used by Python worker (OpenAI Realtime).
# Post-session feedback: used by Go API (gpt-4o-mini) when set; otherwise stub feedback.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_VOICE=alloy

# --- LiveKit ---
# Docker compose defaults: dev server at ws://localhost:7880 with devkey / secret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Must match agent/tutor_agent.py LIVEKIT_AGENT_NAME; empty = no agent in join token
LIVEKIT_AGENT_NAME=fluentflow-tutor

# --- Web (docker build / local) ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Optional ---
ADMIN_TOKEN=
